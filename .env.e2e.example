# User from the haru realm, not the Keycloak console administrator.
E2E_USERNAME=
E2E_PASSWORD=

# Optional: verifies whether the UI exposes the expected actions for the role.
E2E_EXPECTED_ROLE=customer

# Optional read-only scenarios against real data.
E2E_PRODUCT_QUERY=
E2E_PRODUCT_EXPECTED_NAME=
E2E_INVENTORY_PRODUCT_ID=
E2E_PRODUCTION_ORDER_ID=

# Change only when targeting an existing frontend server or another URL.
E2E_BASE_URL=http://localhost:5173
E2E_START_WEB_SERVER=true
